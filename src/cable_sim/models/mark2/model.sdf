      <yVabsV>-0.5</yVabsV> 
      <zWabsW>-0.5</zWabsW>
    </plugin>
    <plugin 
        filename="gz-sim-hydrodynamics-system"
        name="gz::sim::systems::Hydrodynamics">
      <link_name>end_sphere</link_name>
      <water_density>1025</water_density>
      <xU>-0.5</xU> 
      <yV>-0.5</yV>
