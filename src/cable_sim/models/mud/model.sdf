    <!-- Hydrodynamics plugin -->
    <plugin
        filename="gz-sim-hydrodynamics-system"
        name="gz::sim::systems::Hydrodynamics">
      <link_name>base_link</link_name>
      <water_density>1025.0</water_density>

      <xDotU>0</xDotU>
      <yDotV>0</yDotV>
      <zDotW>0</zDotW>
      <kDotP>0</kDotP>
      <mDotQ>0</mDotQ>
      <nDotR>0</nDotR>

      <xU>0</xU>
      <yV>0</yV>
      <zW>0</zW>
      <kP>0</kP>
      <mQ>0</mQ>
      <nR>0</nR>

      <xUabsU>-33.732</xUabsU>
      <yVabsV>-54.16</yVabsV>
      <zWabsW>-73.225</zWabsW>
      <kPabsP>-25</kPabsP>
      <mQabsQ>-25</mQabsQ>
      <nRabsR>-12</nRabsR>
    </plugin>

    <plugin
        filename="gz-sim-thruster-system"
        name="gz::sim::systems::Thruster">
      <namespace>mud</namespace>
      <joint_name>thruster1_joint</joint_name>
      <thrust_coefficient>0.01</thrust_coefficient>
      <fluid_density>1025.0</fluid_density>
      <propeller_diameter>0.07</propeller_diameter>
      <use_angvel_cmd>False</use_angvel_cmd>
    </plugin>

    <plugin
        filename="gz-sim-thruster-system"
