<?xml version='1.0' encoding='UTF-8'?>
<sdf version="1.6">
  <model name="mud">
    <pose>0 0 0 0 0 0</pose>
    <link name="base_link">
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>21.4</mass>
        <inertia>
          <ixx>0.18</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.35</iyy>
          <iyz>0</iyz>
          <izz>0.40</izz>
        </inertia>
      </inertial>
      <velocity_decay>
        <linear>0.2</linear>
        <angular>0.6</angular>
      </velocity_decay>
      <visual name="mud_visual">
        <geometry>
          <mesh>
            <uri>model://mud/meshes/MUD.stl</uri>
            <scale>0.001 0.001 0.001</scale>
          </mesh>
        </geometry>
        <material>
          <ambient>0.15 0.15 0.15 1</ambient>
          <diffuse>0.25 0.25 0.25 1</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>
      <collision name="mud_collision">
        <pose>0 0 0 0 0 0</pose>
        <geometry><box><size>0.65 0.272 0.118</size></box></geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.4</mu>
              <mu2>0.4</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <sensor name="imu_sensor" type="imu">
        <pose>0 0 0 0 0 0</pose>
        <always_on>1</always_on>
        <update_rate>1000.0</update_rate>
      </sensor>
      <light name="light1" type="spot">
        <pose relative_to="base_link">0.18011 -0.056687 0.045 0 -1.5708 0</pose>
        <diffuse>1 1 1 1</diffuse>
        <specular>0.1 0.1 0.1 1</specular>
        <spot>
          <inner_angle>0.3</inner_angle>
          <outer_angle>0.7</outer_angle>
          <falloff>0.9</falloff>
        </spot>
        <attenuation>
          <range>8</range>
          <constant>0.5</constant>
          <linear>0.01</linear>
          <quadratic>0.001</quadratic>
        </attenuation>
        <intensity>0.0</intensity>
        <cast_shadows>false</cast_shadows>
      </light>
      <light name="light2" type="spot">
        <pose relative_to="base_link">0.18011 0.056687 0.045 0 -1.5708 0</pose>
        <diffuse>1 1 1 1</diffuse>
        <specular>0.1 0.1 0.1 1</specular>
        <spot>
          <inner_angle>0.3</inner_angle>
          <outer_angle>0.7</outer_angle>
          <falloff>0.9</falloff>
        </spot>
        <attenuation>
          <range>8</range>
          <constant>0.5</constant>
          <linear>0.01</linear>
          <quadratic>0.001</quadratic>
        </attenuation>
        <intensity>0.0</intensity>
        <cast_shadows>false</cast_shadows>
      </light>
    </link>

    <link name="camera_link">
      <pose relative_to="camera_mount_link">0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.0001</mass>
        <inertia>
          <ixx>0.0001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0001</iyy>
          <iyz>0</iyz>
          <izz>0.0001</izz>
        </inertia>
      </inertial>
      <sensor name="camera_sensor" type="camera">
        <update_rate>15</update_rate>
        <visualize>1</visualize>
        <always_on>1</always_on>
        <topic>/model/mud/camera</topic>
        <camera>
          <horizontal_fov>1.05</horizontal_fov>
          <image>
            <width>1280</width>
            <height>720</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.1</near>
            <far>10.0</far>
          </clip>
        </camera>
      </sensor>
    </link>
    <link name="camera_mount_link">
      <pose relative_to="base_link">0.325 0 0 0 0 0</pose>
      <inertial>
        <mass>0.0001</mass>
        <inertia>
          <ixx>0.0001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0001</iyy>
          <iyz>0</iyz>
          <izz>0.0001</izz>
        </inertia>
      </inertial>
    </link>
    <joint name="camera_tilt_joint" type="revolute">
      <parent>camera_mount_link</parent>
      <child>camera_link</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-0.785398</lower>
          <upper>0.785398</upper>
        </limit>
      </axis>
    </joint>
    <joint name="camera_mount_joint" type="fixed">
      <parent>base_link</parent>
      <child>camera_mount_link</child>
    </joint>

    <link name="tether_mount">
      <pose>0.315 0 0.03 0 0 0</pose>
      <inertial>
        <mass>1e-6</mass>
        <inertia>
          <ixx>1e-9</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>1e-9</iyy>
          <iyz>0</iyz>
          <izz>1e-9</izz>
        </inertia>
      </inertial>
    </link>

    <link name="thruster1">
      <pose>0.22067 0.097356 0 -1.571 1.571 -2.356</pose>
      <visual name="thruster_prop_visual">
        <pose>0 0 0 -1.571 0 0</pose>
        <geometry>
          <mesh>
            <uri>model://mud/meshes/ccw_prop.dae</uri>
          </mesh>
        </geometry>
      </visual>
      <inertial>
        <mass>0.002</mass>
